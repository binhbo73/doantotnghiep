# ====================================
# 🐳 DOCKER COMPOSE ENVIRONMENT (TEMPLATE)
# ====================================
# Sao chép file này thành .env (git-ignored) để sử dụng
# KHÔNG commit vào git - dùng git-ignored file cho secrets

# PostgreSQL Database Configuration
POSTGRES_DB=rag_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres  # THAY ĐỔI!
POSTGRES_HOST=postgres  # docker service name
POSTGRES_PORT=5433

# Backend Configuration
BACKEND_PORT=8000
ENVIRONMENT=development
DEBUG=false

# Django Settings
SECRET_KEY=django-insecure-your-secret-key-min-32-chars-change-this-in-production
ALLOWED_HOSTS='["localhost","127.0.0.1","backend"]'

# CORS Configuration
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]'

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Qdrant Configuration (Vector Database - Production-ready)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant  # THAY ĐỔI!
QDRANT_PERSIST_DIRECTORY=./qdrant_data

# Frontend Configuration (Optional)
FRONTEND_PORT=3000

# AI Model Configuration (Local Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
CHAT_MODEL=qwen2:1.5b
EMBEDDING_MODEL=mxbai-embed-large

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here  # Use Gmail App Passwords
EMAIL_SENDER=noreply@rag-system.local
APP_URL=http://localhost:3000
