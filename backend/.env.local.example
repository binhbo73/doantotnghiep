# ====================================
# 🔧 LOCAL DEVELOPMENT ENVIRONMENT
# ====================================
# Sao chép file này thành .env.local (GIT IGNORED)
# Sử dụng khi chạy LOCAL Django (không phải trong Docker)

# Database Configuration - LOCAL ONLY
POSTGRES_DB=rag_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres  # THAY ĐỔI!
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Security
SECRET_KEY=django-insecure-your-dev-key-here-change-in-production-min-32-chars
DEBUG=True
ALLOWED_HOSTS='["localhost","127.0.0.1"]'

# App
APP_NAME=RAG System API
APP_VERSION=1.0.0

# CORS
CORS_ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:8000"]'

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# ChromaDB (Vector Database) - LOCAL
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./chroma_data

# AI Model Configuration (Local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2:1.5b
EMBEDDING_MODEL=mxbai-embed-large

# Email Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_SENDER=noreply@rag-system.local
APP_URL=http://localhost:3000
