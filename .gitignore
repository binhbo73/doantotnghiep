# ============================================================================
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================
.pre-commit-config.yaml.bak
.ruff_cache/
.mypy_cache/
.pylint.d/

# ============================================================================
# PROJECT-SPECIFIC
# ============================================================================
# Local development overrides
local_settings/
dev_settings/
.local/
.secrets/

# Auto-generated schemas (if applicable)
# schema.graphql
# schema.json

# Binary files (screenshots, generated images)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.ico

# ============================================================================
# CI/CD (Keep workflow files but ignore logs)
# ============================================================================
# .github/ is tracked for CI/CD workflows
# But ignore any generated files inside
.github/**/*.log
.github/**/*.tmp
