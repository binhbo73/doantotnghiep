# ============================================================================
# MEDIA & UPLOADS (except examples)
# ============================================================================
/media/*
!/media/.gitkeep
/uploads/*
!/uploads/.gitkeep
/files/*
!/files/.gitkeep
/downloads/*
!/downloads/.gitkeep

# ============================================================================
# GENERATED FILES (usually auto-generated, not version controlled)
# ============================================================================
# Keep these if they're part of source, comment out if not needed
# dist/
# build/
# *.generated.*

# ============================================================================
# MONITORING & LOGS
# ============================================================================
logs/
*.log
*.log.*
var/log/
sentry.log

# ============================================================================
